# Dependencies
node_modules/

# Environment / secrets
.env
.env.*
*.credentials.json

# OS
.DS_Store
Thumbs.db

# BMad personal overrides (already gitignored in _bmad/custom/ but belt-and-suspenders)
_bmad/custom/*.user.toml

# Claude Code session/cache data (not source artifacts)
.claude/projects/
.claude/cache/
.claude/debug/
.claude/paste-cache/
.claude/session-env/
.claude/shell-snapshots/
.claude/statsig/
.claude/telemetry/
.claude/todos/
.claude/usage-data/
.claude/backups/

# Build output
# `dist/` covers everything under it including `dist/binaries/` (SEA binaries,
# Story 5.2) and `dist/sea-prep/` (intermediate SEA blob output). No separate
# entries needed.
dist/
build/
coverage/

# Large perf fixtures (materialized at runtime by builder script)
tests/fixtures/large-bundles/

# Dev scratch scripts (not part of the build)
_compute_hashes.mjs
